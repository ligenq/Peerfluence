{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build Peerfluence",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Peerfluence/Peerfluence.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run Peerfluence",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/Peerfluence/Peerfluence.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch Peerfluence",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/Peerfluence/Peerfluence.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish Peerfluence",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/Peerfluence/Peerfluence.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build VisualDebugger",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/VisualDebugger/VisualDebugger.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch VisualDebugger",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/VisualDebugger/VisualDebugger.csproj"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
