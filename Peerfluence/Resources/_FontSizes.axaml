<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="using:System">

	<sys:Double x:Key="FontSizeTiny">10</sys:Double>
	<sys:Double x:Key="FontSizeSmall">11</sys:Double>
	<sys:Double x:Key="FontSizeNormal">12</sys:Double>
	<sys:Double x:Key="FontSizeMedium">14</sys:Double>
	<sys:Double x:Key="FontSizeLarge">18</sys:Double>
	<sys:Double x:Key="FontSizeXLarge">20</sys:Double>
	<sys:Double x:Key="FontSizeTitle">24</sys:Double>
	<sys:Double x:Key="FontSizeHeader">28</sys:Double>

</ResourceDictionary>
