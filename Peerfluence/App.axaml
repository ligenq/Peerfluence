<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Peerfluence"
             xmlns:converters="using:Peerfluence.Converters"
             xmlns:suki="clr-namespace:SukiUI;assembly=SukiUI"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="Peerfluence.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Peerfluence/Resources/_Colors.axaml"/>
                <ResourceInclude Source="avares://Peerfluence/Resources/_Thickness.axaml"/>
                <ResourceInclude Source="avares://Peerfluence/Resources/_Spacings.axaml"/>
                <ResourceInclude Source="avares://Peerfluence/Resources/_FontSizes.axaml"/>
                <ResourceInclude Source="avares://Peerfluence/Resources/_IconSizes.axaml"/>
                <ResourceInclude Source="avares://Peerfluence/Resources/_CornerRadii.axaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:ByteSizeConverter x:Key="ByteSizeConverter"/>
            <converters:SpeedConverter x:Key="SpeedConverter"/>
            <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>


        </ResourceDictionary>
    </Application.Resources>
  
    <Application.Styles>
        <suki:SukiTheme ThemeColor="Blue" />
        <materialIcons:MaterialIconStyles />


    </Application.Styles>
</Application>
